/**
 * @file version.h
 * @brief Auto-generated version information from CMake project configuration
 * @details Do not edit this file directly. It is generated from version.h.in
 *          by CMake's configure_file() using the VERSION set in CMakeLists.txt.
 */

#ifndef VERSION_H
#define VERSION_H

/* Numeric version components */
#define VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define VERSION_MINOR @PROJECT_VERSION_MINOR@
#define VERSION_PATCH @PROJECT_VERSION_PATCH@

/* Version string (narrow, usable in both C code and resource scripts) */
#define VERSION_STR "@PROJECT_VERSION@"

#ifndef RC_INVOKED
/* Wide version string (only for C code, not available in resource compiler) */
#define VERSION_STR_W L"@PROJECT_VERSION@"
#endif

#endif /* VERSION_H */
